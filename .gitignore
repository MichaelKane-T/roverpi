# =============================================================================
# RoverPi .gitignore
# Raspberry Pi (Python/Flask) + ESP32 (ESP-IDF)
# =============================================================================

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/


# Virtual environments
.venv/
venv/
ENV/
env/
.sh

# -----------------------------------------------------------------------------
# ESP-IDF Build Output
# -----------------------------------------------------------------------------
build/
sdkconfig
sdkconfig.old
dependencies.lock

# ESP-IDF managed components
managed_components/
.sh

# -----------------------------------------------------------------------------
# Flask / Web
# -----------------------------------------------------------------------------
instance/
.webassets-cache
flask_session/

# -----------------------------------------------------------------------------
# Environment & Secrets
# -----------------------------------------------------------------------------
.env
.env.*
*.secret
secrets.py
config.local.py

# -----------------------------------------------------------------------------
# OS Files
# -----------------------------------------------------------------------------

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# -----------------------------------------------------------------------------
# Editors & IDEs
# -----------------------------------------------------------------------------

# VS Code
.vscode/
*.code-workspace

# JetBrains / CLion
.idea/
*.iml
*.iws
cmake-build-*/

# Vim / Emacs
*.swp
*.swo
*.bak
*~
\#*\#
.#*

# -----------------------------------------------------------------------------
# Logs & Runtime
# -----------------------------------------------------------------------------
*.log
logs/
*.pid
*.sock

# -----------------------------------------------------------------------------
# Media / Large Assets
# -----------------------------------------------------------------------------
docs/videos/*.mp4
docs/videos/*.avi
docs/videos/*.mov
docs/images/raw/

# Keep placeholder dirs
!docs/images/.gitkeep
!docs/videos/.gitkeep

# -----------------------------------------------------------------------------
# Jupyter (if used for ML experiments)
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb

# -----------------------------------------------------------------------------
# Compiled / Binary
# -----------------------------------------------------------------------------
*.o
*.a
*.so
*.elf
*.bin
*.hex
*.map


# Node/Vite junk
app/node_modules/
app/.vite/
app/.cache/
app/npm-debug.log*
app/yarn-debug.log*
app/yarn-error.log*
app/pnpm-debug.log*

# Optional: ignore local env files
app/.env
app/.env.local

# Python junk
__pycache__/
*.pyc
.venv/
venv/

# OS/editor junk
.DS_Store
.vscode/
.idea/